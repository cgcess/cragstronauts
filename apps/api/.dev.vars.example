# Local Clerk keys for `wrangler dev`. Copy this file to `.dev.vars` (gitignored)
# and fill in, or let the Clerk CLI write them for you:
#   npx clerk env pull --app <your_app_id> --file apps/api/.dev.vars
#
# Find them on the Clerk dashboard API keys page. CLERK_PUBLISHABLE_KEY is safe
# to expose; CLERK_SECRET_KEY is a secret. In production set both as Worker vars,
# the secret via `wrangler secret put CLERK_SECRET_KEY`.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Discord notifications (docs/discord-events.md). Both are secrets: never commit
# real values. Locally set them here (in .dev.vars); in production use
# `wrangler secret put`. The signing secret (whsec_...) comes from the Clerk
# dashboard webhook endpoint; DISCORD_WEBHOOK_URL is a Discord incoming webhook
# for the channel that receives signups plus in-app business events. Leave it
# unset locally to keep dev silent.
CLERK_WEBHOOK_SIGNING_SECRET=
DISCORD_WEBHOOK_URL=

# Web Push / VAPID (docs/web-push.md). Generate a keypair once with
# `npx @pushforge/builder vapid`. VAPID_PRIVATE_KEY is the printed JWK JSON
# string (a secret — in production `wrangler secret put VAPID_PRIVATE_KEY`);
# VAPID_PUBLIC_KEY is the printed base64url key (also set as the frontend's
# VITE_VAPID_PUBLIC_KEY); VAPID_SUBJECT is a mailto: contact URL. Leave all
# three unset locally to keep push silent.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=
