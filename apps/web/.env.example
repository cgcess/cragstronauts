# Clerk publishable key for the frontend. Safe to expose (it ships in the client
# bundle). Get it from the Clerk dashboard API keys page or `npx clerk env pull`.
# Development keys start with pk_test_. Copy to .env.local (gitignored) for dev.
VITE_CLERK_PUBLISHABLE_KEY=

# Web Push VAPID public key (docs/web-push.md). Safe to expose — it ships in the
# client bundle as the push `applicationServerKey`. This is the base64url public
# key printed by `npx @pushforge/builder vapid` (the same value set as the API's
# VAPID_PUBLIC_KEY). Leave unset to hide the "Enable notifications" control.
VITE_VAPID_PUBLIC_KEY=
