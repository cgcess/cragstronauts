#!/usr/bin/env bash
set -euo pipefail

# Populate local Clerk secrets so the app can boot. Clerk is required: without
# these files `pnpm turbo dev` (and the web build) will fail fast.
#
# Uses the Clerk CLI (no vault). Prerequisites:
#   - membership in the Clerk app, and
#   - a logged-in Clerk CLI session (the pull will prompt if needed).
#
# Produces (both gitignored):
#   - apps/api/.dev.vars      Worker runtime keys (CLERK_PUBLISHABLE_KEY + CLERK_SECRET_KEY)
#   - apps/web/.env.local     Vite build key (VITE_CLERK_PUBLISHABLE_KEY)

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CLERK_APP="app_3FJAeiPJvMuQS9Yfo3X0ivLoaRO"
DEV_VARS="$ROOT/apps/api/.dev.vars"
ENV_LOCAL="$ROOT/apps/web/.env.local"

echo "=== Pulling Clerk keys into apps/api/.dev.vars ==="
npx clerk env pull --app "$CLERK_APP" --file "$DEV_VARS"

echo "=== Deriving apps/web/.env.local (VITE_CLERK_PUBLISHABLE_KEY) ==="
PUB_KEY="$(grep -E '^CLERK_PUBLISHABLE_KEY=' "$DEV_VARS" | head -1 | cut -d= -f2-)"
if [ -z "$PUB_KEY" ]; then
  echo "error: CLERK_PUBLISHABLE_KEY not found in $DEV_VARS" >&2
  exit 1
fi
printf 'VITE_CLERK_PUBLISHABLE_KEY=%s\n' "$PUB_KEY" > "$ENV_LOCAL"

echo "=== Done. Local Clerk secrets are set. ==="
