#!/usr/bin/env bash
set -euo pipefail

# Pull local secrets from ZeroVault so the app can boot. These files are
# generated — never hand-edit them. See docs/secrets.md for setup.
#
# Auth: resolution is `--api-key flag > per-dir context > env > default`. Locally
# the repo directory is bound to the `cragstronauts` context (`zv context use`),
# so plain `zv` targets the right org even with a global ZEROVAULT_API_KEY for
# another org. In CI the ZEROVAULT_API_KEY env var is used (no local binding).
#
# Produces (all gitignored):
#   - apps/api/.dev.vars        Worker runtime env  (cragstronauts-worker / development)
#   - apps/web/.env.local       Vite dev vars       (cragstronauts-web / development)
#   - apps/web/.env.production   Vite prod build vars (cragstronauts-web / production)

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ZV="pnpm exec zv"

echo "=== apps/api/.dev.vars (cragstronauts-worker / development) ==="
$ZV secrets download -p cragstronauts-worker -e development --format env \
  --output "$ROOT/apps/api/.dev.vars"

echo "=== apps/web/.env.local (cragstronauts-web / development) ==="
$ZV secrets download -p cragstronauts-web -e development --format env \
  --output "$ROOT/apps/web/.env.local"

echo "=== apps/web/.env.production (cragstronauts-web / production) ==="
$ZV secrets download -p cragstronauts-web -e production --format env \
  --output "$ROOT/apps/web/.env.production"

echo "=== Done. Local secrets are set. ==="
