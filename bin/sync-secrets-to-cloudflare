#!/usr/bin/env bash
set -euo pipefail

# Push the production Worker secrets from ZeroVault to Cloudflare in one call.
# `wrangler secret bulk` reads a JSON { KEY: value } map from stdin and sets
# every secret on the `cragstronauts` worker. See docs/secrets.md.
#
# Run from the repo root so the `cragstronauts` context binding applies (plain
# `zv` targets the right org). Sanity-check with `pnpm exec zv whoami` first.

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ZV="pnpm exec zv"

echo "=== Syncing cragstronauts-worker / production secrets to Cloudflare ==="
$ZV secrets download -p cragstronauts-worker -e production --format json | \
  pnpm --dir "$ROOT/apps/api" exec wrangler secret bulk

echo "=== Done. ==="
