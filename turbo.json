{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "@cragstronauts/api#dev": {
      "dependsOn": ["@cragstronauts/web#build"],
      "persistent": true,
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@cragstronauts/api#deploy": {
      "dependsOn": ["@cragstronauts/web#build"],
      "cache": false
    },
    "typecheck": {}
  }
}
